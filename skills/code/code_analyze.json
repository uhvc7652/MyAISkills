{
  "name": "code_analyze",
  "description": "对给定的代码进行静态分析，识别潜在问题、代码风格问题、安全漏洞，并给出改进建议。",
  "category": "code",
  "version": "1.0.0",
  "parameters": {
    "type": "object",
    "properties": {
      "code": {
        "type": "string",
        "description": "需要分析的代码字符串"
      },
      "language": {
        "type": "string",
        "description": "编程语言",
        "enum": ["python", "javascript", "typescript", "java", "go", "rust"]
      },
      "checks": {
        "type": "array",
        "description": "要执行的检查类型列表",
        "items": {
          "type": "string",
          "enum": ["syntax", "style", "security", "performance", "complexity"]
        },
        "default": ["syntax", "style", "security"]
      }
    },
    "required": ["code", "language"]
  },
  "returns": {
    "type": "object",
    "description": "包含问题列表（每项含行号、严重程度、描述）和整体评分"
  },
  "examples": [
    {
      "input": {
        "code": "password = '123456'\nprint(password)",
        "language": "python",
        "checks": ["security"]
      },
      "output": {
        "score": 40,
        "issues": [
          {
            "line": 1,
            "severity": "high",
            "type": "security",
            "message": "硬编码明文密码，存在安全风险，建议使用环境变量或密钥管理服务"
          }
        ]
      }
    }
  ]
}
